<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- SSH profiles can contain credentials, so keep the Room database out of cloud backup. -->
        <exclude domain="database" path="ssh_proxy_database" />
        <exclude domain="database" path="ssh_proxy_database-shm" />
        <exclude domain="database" path="ssh_proxy_database-wal" />
    </cloud-backup>
    <device-transfer>
        <!-- Avoid transferring plaintext credentials until encrypted storage is introduced. -->
        <exclude domain="database" path="ssh_proxy_database" />
        <exclude domain="database" path="ssh_proxy_database-shm" />
        <exclude domain="database" path="ssh_proxy_database-wal" />
    </device-transfer>
</data-extraction-rules>
